{
  "endpoint": "/perfil",
  "descripcion": "Selectores XPath para app-piloto-testing. Flujo completo: /login → /dashboard → /perfil",
  "elementos": [

    {
      "pantalla": "/login",
      "nombre": "campo_usuario",
      "descripcion": "Campo de texto para el nombre de usuario",
      "xpath": "//input[@id='username']"
    },
    {
      "pantalla": "/login",
      "nombre": "campo_password",
      "descripcion": "Campo de contraseña",
      "xpath": "//input[@id='password']"
    },
    {
      "pantalla": "/login",
      "nombre": "boton_entrar",
      "descripcion": "Botón de envío del formulario de login",
      "xpath": "//button[normalize-space()='Entrar']"
    },
    {
      "pantalla": "/login",
      "nombre": "mensaje_error_login",
      "descripcion": "Mensaje de error de credenciales inválidas",
      "xpath": "//div[@id='error-msg']"
    },

    {
      "pantalla": "/dashboard",
      "nombre": "select_categoria_busqueda",
      "descripcion": "Dropdown de categoría para búsqueda rápida",
      "xpath": "//select[@id='cat']"
    },
    {
      "pantalla": "/dashboard",
      "nombre": "campo_busqueda",
      "descripcion": "Campo de texto para búsqueda rápida",
      "xpath": "//input[@id='q']"
    },
    {
      "pantalla": "/dashboard",
      "nombre": "boton_buscar",
      "descripcion": "Botón para ejecutar la búsqueda",
      "xpath": "//button[normalize-space()='Buscar']"
    },
    {
      "pantalla": "/dashboard",
      "nombre": "boton_editar_perfil",
      "descripcion": "Botón de acceso rápido a la pantalla de perfil",
      "xpath": "//a[normalize-space()='Editar Perfil'] | //button[normalize-space()='Editar Perfil']"
    },
    {
      "pantalla": "/dashboard",
      "nombre": "boton_configuracion",
      "descripcion": "Botón de acceso rápido a la pantalla de configuración",
      "xpath": "//a[normalize-space()='Configuración'] | //button[normalize-space()='Configuración']"
    },
    {
      "pantalla": "/dashboard",
      "nombre": "boton_logout",
      "descripcion": "Botón para cerrar sesión",
      "xpath": "//a[normalize-space()='Logout'] | //button[normalize-space()='Logout']"
    },

    {
      "pantalla": "/perfil",
      "nombre": "campo_nombre",
      "descripcion": "Campo de nombre completo del usuario",
      "xpath": "//input[@id='nombre']"
    },
    {
      "pantalla": "/perfil",
      "nombre": "campo_email",
      "descripcion": "Campo de email del usuario",
      "xpath": "//input[@id='email']"
    },
    {
      "pantalla": "/perfil",
      "nombre": "campo_telefono",
      "descripcion": "Campo de teléfono del usuario (opcional)",
      "xpath": "//input[@id='telefono']"
    },
    {
      "pantalla": "/perfil",
      "nombre": "select_departamento",
      "descripcion": "Selector de departamento",
      "xpath": "//select[@id='departamento']"
    },
    {
      "pantalla": "/perfil",
      "nombre": "select_ciudad",
      "descripcion": "Selector de ciudad",
      "xpath": "//select[@id='ciudad']"
    },
    {
      "pantalla": "/perfil",
      "nombre": "select_idioma",
      "descripcion": "Selector de idioma preferido",
      "xpath": "//select[@id='idioma']"
    },
    {
      "pantalla": "/perfil",
      "nombre": "campo_pass_actual",
      "descripcion": "Campo de contraseña actual (sección cambio de contraseña)",
      "xpath": "//input[@id='pass_actual']"
    },
    {
      "pantalla": "/perfil",
      "nombre": "campo_pass_nueva",
      "descripcion": "Campo de contraseña nueva",
      "xpath": "//input[@id='pass_nueva']"
    },
    {
      "pantalla": "/perfil",
      "nombre": "campo_pass_confirmar",
      "descripcion": "Campo de confirmación de nueva contraseña",
      "xpath": "//input[@id='pass_confirmar']"
    },
    {
      "pantalla": "/perfil",
      "nombre": "boton_guardar_cambios",
      "descripcion": "Botón para guardar los cambios del perfil",
      "xpath": "//button[normalize-space()='Guardar Cambios']"
    },
    {
      "pantalla": "/perfil",
      "nombre": "boton_cancelar_perfil",
      "descripcion": "Botón para cancelar y volver al dashboard",
      "xpath": "//a[normalize-space()='Cancelar'] | //button[normalize-space()='Cancelar']"
    }
  ]
}
